# виртуальное окружение
.venv/

# кэш питона
__pycache__/
*.pyc

# базы данных
*.db

# настройки и секреты
.env

# IDE
.idea/
.vscode/

# системные файлы macOS
.DS_Store

# Generated LaTeX/PDF artifacts
backend/static/generated/pdf/
backend/static/generated/temp/
backend/static/generated/charts/

# Persistent user-editable settings (хранится в persistent volume на
# продакшен-сервере, рядом с БД). Дефолтные значения всегда лежат в
# Python-константах (segment_analysis_module.SEGMENT_THRESHOLDS и т.п.)
# и подгружаются если файла нет — потеря файла НЕ ломает систему.
backend/data/*.json
!backend/data/.gitkeep

# Runtime logs
logs/
*.aux
*.log
*.out
*.toc
*.synctex.gz

# Data files (LoRa sensor dumps)
data/

# Misc
Telegram Events.session.sql
Без названия.json
venv/
.claude/.hook-state/
